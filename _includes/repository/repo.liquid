{% assign repo_url = include.repository | split: '/' %}

<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.repository }}" style="text-decoration: none; color: inherit;">
    <div class="card" style="display: inline-block; padding: 1.5rem; border: 1px solid #e1e4e8; border-radius: 6px; max-width: 400px;">
      <img
        alt="{{ repo_url[0] }}"
        src="https://avatars.githubusercontent.com/{{ repo_url[0] }}?s=40"
        style="width: 40px; height: 40px; border-radius: 50%; margin-bottom: 0.5rem;"
      >
      <h4 style="margin: 0;">{{ repo_url[1] }}</h4>
      <p style="margin: 0.5rem 0 0; color: #586069; font-size: 0.9rem;">{{ repo_url[0] }}/{{ repo_url[1] }}</p>
    </div>
  </a>
</div>
