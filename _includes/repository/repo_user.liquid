<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.username }}" style="text-decoration: none; color: inherit;">
    <div class="card" style="display: inline-block; padding: 1.5rem; border: 1px solid #e1e4e8; border-radius: 6px; max-width: 400px;">
      <img
        alt="{{ include.username }}"
        src="https://avatars.githubusercontent.com/{{ include.username }}?s=100"
        style="width: 100px; height: 100px; border-radius: 50%; margin-bottom: 0.75rem;"
      >
      <h4 style="margin: 0;">{{ include.username }}</h4>
    </div>
  </a>
</div>
